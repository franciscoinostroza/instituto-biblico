APP_NAME="Instituto Bíblico"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# PostgreSQL (Railway provee DATABASE_URL automáticamente en producción)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=instituto_biblico
DB_USERNAME=postgres
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database
CACHE_STORE=database

# S3 / Cloudflare R2 / MinIO para archivos y avatares
# Desarrollo local con MinIO: levantar con Docker (ver README)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=instituto-biblico
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@institutobiblico.edu.ar"
MAIL_FROM_NAME="${APP_NAME}"

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173
